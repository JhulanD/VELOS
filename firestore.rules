rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper for key verification (Lists don't have hasOnly, but sets from diff do)
    // For creation, we check size and hasAll.

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email'])
          && data.uid is string && data.uid.size() <= 128
          && data.name is string && data.name.size() <= 128
          && data.email is string && data.email.size() <= 255;
    }

    function isValidCandidate(data) {
      return data.keys().hasAll(['name', 'status'])
          && data.name is string && data.name.size() <= 128
          && data.status in ['sourced', 'screening', 'interview', 'offer_sent', 'placed', 'rejected']
          && (!('aiScore' in data) || (data.aiScore is int && data.aiScore >= 0 && data.aiScore <= 100))
          && (!('ownerId' in data) || isValidId(data.ownerId));
    }

    function isValidJob(data) {
      return data.keys().hasAll(['title', 'company', 'status'])
          && data.title is string && data.title.size() <= 256
          && data.company is string && data.company.size() <= 256
          && data.status in ['active', 'closed', 'draft'];
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'priority', 'status', 'order', 'completed', 'ownerId'])
          && data.title is string && data.title.size() <= 512
          && data.priority in ['low', 'medium', 'high']
          && data.status in ['todo', 'in_progress', 'done']
          && data.order is int
          && data.completed is bool
          && isValidId(data.ownerId);
    }

    // --- Match Blocks ---

    match /users/{userId} {
      // Identity Poisoning Guard
      allow get: if isSignedIn() && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming())
                    && incoming().uid == existing().uid;
    }

    match /candidates/{candidateId} {
      allow get: if isSignedIn() && isValidId(candidateId);
      // Secure List Query: Enforce that only participants/recruiters can list
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && isValidCandidate(incoming());
      allow update: if isSignedIn() && isValidCandidate(incoming());
      allow delete: if isSignedIn(); // Add admin check if needed
    }

    match /jobs/{jobId} {
      allow get: if isSignedIn() && isValidId(jobId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidJob(incoming());
      allow update: if isSignedIn() && isValidJob(incoming());
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && isValidId(taskId) && existing().ownerId == request.auth.uid;
      // Secure List Queries: Evaluation of resource.data against request.auth.uid
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidTask(incoming()) 
                    && incoming().ownerId == request.auth.uid;
                    
      allow update: if isSignedIn() && isValidTask(incoming())
                    && existing().ownerId == request.auth.uid
                    && incoming().ownerId == existing().ownerId;
                    
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /test/{docId} {
       allow read: if isSignedIn(); // For connection test
    }
  }
}
